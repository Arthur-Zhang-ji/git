{
  "manifest_version": 3,
  "name": "抖音高清截帧",
  "version": "1.0.0",
  "description": "一键保存抖音视频中的高清画面帧，支持逐帧步进和快捷键操作",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "抖音高清截帧"
  },
  "content_scripts": [
    {
      "matches": ["*://*.douyin.com/*", "*://*.iesdouyin.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ],
  "permissions": []
}
